  const lerp = (a, b, t) => a + (b - a) * t;
  // Smoothstep easing for the morph phase
  const smoothstep = (t) => t * t * (3 - 2 * t);

  let targetTime = 0;
  let currentTime = 0;

  function onScroll(){
    measureAnchor();
    const rect = section.getBoundingClientRect();
    const scrollable = section.offsetHeight - window.innerHeight;
    let rawProgress = (-rect.top) / scrollable;
    rawProgress = Math.max(0, Math.min(1, rawProgress));

    const totalMult = (typeof TWEAKS.scrubPinHeight === 'number') ? TWEAKS.scrubPinHeight : 3.5;
    const morphEnd = 1 / (totalMult + 1); // fraction taken by the 1vh morph segment

    const morphP = Math.min(1, rawProgress / morphEnd);
    const scrubP = rawProgress; // Video scrubs concurrently with the scroll from the start
    const morphEased = smoothstep(morphP);

    // --- Morph the stage from anchor rect to fullscreen
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const left   = lerp(startRect.left, 0, morphEased);
    const top    = lerp(startRect.top, 0, morphEased);
    const width  = lerp(startRect.width, vw, morphEased);
    const height = lerp(startRect.height, vh, morphEased);
    stage.style.left   = left + 'px';
    stage.style.top    = top + 'px';
    stage.style.width  = width + 'px';
    stage.style.height = height + 'px';

    // --- Hero content fades and lifts slightly during morph
    const heroOpacity = 1 - morphEased;
    heroInner.style.opacity = heroOpacity;
    heroInner.style.transform = `translateY(${-morphEased * 40}px)`;
    heroInner.style.pointerEvents = morphEased > 0.5 ? 'none' : '';

    // --- Sketch overlay fades out as video takes over (faster than hero)
    if (sketchOverlay){
