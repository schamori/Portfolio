    if (progressBar) progressBar.classList.toggle('visible', morphEased > 0.6);
    if (label) label.classList.toggle('visible', morphEased > 0.6 && TWEAKS.showScrubLabel);

    // --- Scrub mode: video.currentTime is driven by scroll position.
    const curveVal = TWEAKS.scrubMultiplier;
    const curveMult = (typeof curveVal === 'number') ? curveVal : 1;
    // If multiplier is 1, it's a direct linear 1:1 scroll.
    const scrubEased = (curveMult === 1) ? scrubP : Math.pow(scrubP, 1 / Math.max(0.1, curveMult));

    if (video.duration && !isNaN(video.duration)){
      targetTime = scrubEased * video.duration;
    }
    if (fill) fill.style.width = (scrubP * 100) + '%';
