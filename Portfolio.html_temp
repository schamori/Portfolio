  if (!video || !section || !stage || !anchor) return;

  // Set the pin track height: 1 vh of "hero visible" + N vh of scrub.
  function applyPinHeight(){
    const val = TWEAKS.scrubPinHeight;
    const mult = (typeof val === 'number') ? Math.max(0.1, val) : 3.5;
    // +1 so the first viewport-height of scroll is the morph, then scrub plays for mult vh
    section.style.height = ((mult + 1) * 100) + 'vh';
  }
  applyPinHeight();

  // Measure sketch anchor rect inside the sticky. The stage is absolutely positioned
  // within .hero-sticky, so we use offsets relative to it.
  let startRect = { left: 0, top: 0, width: 300, height: 300 };
  function measureAnchor(){
    const aRect = anchor.getBoundingClientRect();
    const sRect = sticky.getBoundingClientRect();
    startRect = {
      left: aRect.left - sRect.left,
      top:  aRect.top  - sRect.top,
      width: Math.max(aRect.width, 280),
      height: Math.max(aRect.height, 220)
    };
